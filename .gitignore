cat > .gitignore << 'EOF'
# Python Cache
__pycache__/
*.py[cod]
*$py.class

# Jupyter Notebooks
.ipynb_checkpoints/

# Virtual Environments
venv/
env/
.venv/

# PyTorch Model Checkpoints
checkpoints/
*.pth
*.pt

# Data (Never commit massive MRI datasets)
*.nii
*.nii.gz

# OS Generated Files
.DS_Store

# IDE
.vscode/
.idea/
EOF